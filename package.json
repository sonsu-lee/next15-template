{
  "name": "next-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "pnpm fmt:check && pnpm lint && pnpm typecheck && pnpm build",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
